{
  "hosting": {
    "ignore": [
      "firebase-debug.log",
      "firebase-debug.*.log"
    ],
    "rewrites": [
      {
        "source": "/v1/overlay",
        "run": {
          "serviceId": "agg-overlay",
          "region": "europe-central2",
          "pinTag": true
        }
      },
      {
        "source": "**",
        "run": {
          "serviceId": "agg-api",
          "region": "europe-central2",
          "pinTag": true
        }
      }
    ]
  }
}
